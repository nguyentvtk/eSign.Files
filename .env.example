PORT=3000

# ─── Database ───
# Local dev: dùng SQLite ở data/esign.db
DB_PATH=./data/esign.db
# Production: dùng Turso (libSQL). Cài: https://turso.tech
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token

# ─── JWT Authentication ───
JWT_SECRET=change-me-to-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800

# ─── OTP (2FA) ───
OTP_ISSUER=eSign

# ─── Upload ───
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25

# ─── Dropbox API ───
# Token của tài khoản lãnh đạo (người ký duyệt)
# Tạo tại: https://www.dropbox.com/developers/apps
DROPBOX_ACCESS_TOKEN=
DROPBOX_FOLDER=/eSign/TaiLieuTrinhKy
DROPBOX_SHARED_LINK=

# ─── Telegram Bot ───
# Tạo bot qua @BotFather, lấy token
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

# ─── Email SMTP (tùy chọn) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
