# ╔══════════════════════════════════════════════════════════════════════════╗
# ║                    eSign.Files — Environment Variables                    ║
# ║                                                                          ║
# ║  Copy file này thành `.env` và điền các giá trị thật vào.                 ║
# ║      cp .env.example .env                                                ║
# ║                                                                          ║
# ║  TRÊN VERCEL: copy từng dòng vào Settings → Environment Variables        ║
# ║  Tick cả 3 environments: Production / Preview / Development              ║
# ╚══════════════════════════════════════════════════════════════════════════╝


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ ① SERVER — Cấu hình cơ bản                                                │
# ╰──────────────────────────────────────────────────────────────────────────╯
PORT=3000
NODE_ENV=development


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ ② DATABASE — Cách 1: Local SQLite (dev)                                  │
# │                                                                          │
# │ Chạy local trên máy bạn — DB lưu file trong thư mục `data/`.             │
# │ Không cần đăng ký dịch vụ. Dùng cho development & testing.               │
# ╰──────────────────────────────────────────────────────────────────────────╯
DB_PATH=./data/esign.db


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ ② DATABASE — Cách 2: Turso (production trên Vercel)                      │
# │                                                                          │
# │ BẮT BUỘC khi deploy lên Vercel (vì serverless không có disk persistent). │
# │ Free tier 9GB tại https://turso.tech                                     │
# │                                                                          │
# │ HƯỚNG DẪN LẤY 2 GIÁ TRỊ NÀY:                                              │
# │   1. Truy cập https://app.turso.tech → Sign in (GitHub)                  │
# │   2. Create Database → name=esign-files, location=sin (Singapore)        │
# │   3. Tab "Connect" → copy "Database URL" → paste vào TURSO_DATABASE_URL  │
# │   4. Tab "Tokens" → Generate Token → copy → paste vào TURSO_AUTH_TOKEN   │
# │                                                                          │
# │ HOẶC dùng CLI:                                                            │
# │   curl -sSfL https://get.tur.so/install.sh | bash                        │
# │   turso auth login                                                       │
# │   turso db create esign-files --location sin                             │
# │   turso db show esign-files --url        → TURSO_DATABASE_URL            │
# │   turso db tokens create esign-files     → TURSO_AUTH_TOKEN              │
# ╰──────────────────────────────────────────────────────────────────────────╯
TURSO_DATABASE_URL=libsql://YOUR-DB-NAME-USERNAME.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9.PASTE-YOUR-LONG-TOKEN-HERE


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ ③ JWT AUTHENTICATION — Khoá bí mật ký token                                │
# │                                                                          │
# │ BẮT BUỘC. Chuỗi hex ngẫu nhiên 64 ký tự (256 bit entropy).                │
# │                                                                          │
# │ TẠO BẰNG:                                                                 │
# │   openssl rand -hex 32                                                   │
# │   # hoặc                                                                  │
# │   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"│
# │                                                                          │
# │ ⚠️  KHÔNG dùng 2 giá trị mẫu bên dưới cho production — đổi ngay!           │
# │ ⚠️  Mỗi project nên có secret riêng. Không share giữa các deployment.     │
# ╰──────────────────────────────────────────────────────────────────────────╯
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING_e.g._1b5b72d8f8f74ebd8cbeddfb367331522d232f1f896595080afb707973e861eb
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_HEX_STRING_DIFFERENT_FROM_JWT_SECRET

# Thời gian sống của token (giây)
JWT_ACCESS_TTL=3600           # Access token: 1 giờ
JWT_REFRESH_TTL=604800        # Refresh token: 7 ngày


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ ④ OTP — Xác thực 2 lớp (TOTP / Google Authenticator)                      │
# ╰──────────────────────────────────────────────────────────────────────────╯
OTP_ISSUER=eSign


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ ⑤ FILE UPLOAD                                                             │
# │                                                                          │
# │ • Local dev: dùng thư mục `./uploads`                                    │
# │ • Vercel:    tự động dùng `/tmp/uploads` (override trong code)           │
# ╰──────────────────────────────────────────────────────────────────────────╯
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ ⑥ DROPBOX — Lưu trữ tài liệu (tài khoản LÃNH ĐẠO ký duyệt)                 │
# │                                                                          │
# │ Khi nhân viên upload PDF + đính kèm → tự động đẩy vào Dropbox của        │
# │ lãnh đạo. Cấu trúc folder:                                                │
# │   /eSign/TaiLieuTrinhKy/YYYY-MM/<MaDoc>_<MaNV>/                          │
# │                                                                          │
# │ HƯỚNG DẪN LẤY TOKEN:                                                      │
# │   1. https://www.dropbox.com/developers/apps                             │
# │   2. Create app → "Scoped access" → "Full Dropbox"                       │
# │   3. App name tuỳ chọn (vd: "eSign Files Storage")                       │
# │   4. Tab Permissions, bật:                                                │
# │        ✓ files.content.write                                             │
# │        ✓ files.content.read                                              │
# │        ✓ sharing.write                                                   │
# │        ✓ sharing.read                                                    │
# │   5. Tab Settings → Generate access token                                │
# │   6. Copy token bắt đầu bằng "sl.u..."                                    │
# │                                                                          │
# │ ⚠️  Nếu để trống: file sẽ lưu local (Vercel: /tmp, sẽ MẤT khi cold start)│
# │                                                                          │
# │ LƯU Ý: TOKEN TĨNH HẾT HẠN SAU 4 GIỜ!                                       │
# │ Để TỰ ĐỘNG refresh, dùng OAuth Refresh Token flow:                        │
# │   1. App Console → "OAuth 2" → bật "Allow refresh tokens"                 │
# │   2. App key + App secret → copy vào DROPBOX_APP_KEY / DROPBOX_APP_SECRET │
# │   3. Truy cập:                                                            │
# │      https://www.dropbox.com/oauth2/authorize?client_id=<APP_KEY>         │
# │        &response_type=code&token_access_type=offline                      │
# │   4. Authorize → nhận authorization code                                  │
# │   5. Đổi code → refresh_token bằng:                                        │
# │      curl https://api.dropboxapi.com/oauth2/token \                       │
# │        -d code=<CODE> -d grant_type=authorization_code \                   │
# │        -u <APP_KEY>:<APP_SECRET>                                          │
# │   6. Copy refresh_token vào DROPBOX_REFRESH_TOKEN                         │
# │                                                                          │
# │ Khi có refresh_token: KHÔNG cần DROPBOX_ACCESS_TOKEN (server tự lấy)      │
# ╰──────────────────────────────────────────────────────────────────────────╯
DROPBOX_ACCESS_TOKEN=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_FOLDER=/eSign/TaiLieuTrinhKy
DROPBOX_SHARED_LINK=https://www.dropbox.com/scl/fo/your-shared-folder-link


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ ⑦ TELEGRAM BOT — Thông báo tài liệu trình ký                              │
# │                                                                          │
# │ Khi nhân viên gửi tài liệu → bot gửi thông báo vào group/channel.        │
# │                                                                          │
# │ HƯỚNG DẪN TẠO BOT:                                                        │
# │   1. Mở Telegram, search @BotFather                                       │
# │   2. /newbot → đặt tên bot → @BotFather trả về token                     │
# │   3. Copy token (định dạng: 1234567890:ABC...)                           │
# │                                                                          │
# │ HƯỚNG DẪN LẤY CHAT_ID:                                                    │
# │   1. Thêm bot vào group/channel                                          │
# │   2. Gửi 1 message bất kỳ trong group                                    │
# │   3. Truy cập: https://api.telegram.org/bot<TOKEN>/getUpdates           │
# │   4. Tìm "chat":{"id": -100... } → đó là CHAT_ID                         │
# │                                                                          │
# │ TOPIC_ID (chỉ dùng nếu group bật "Topics"):                              │
# │   • URL message của topic: https://t.me/c/<chat>/<topic_id>/<msg_id>    │
# │   • topic_id là số ở giữa                                                │
# │   • Để trống nếu không dùng topic                                         │
# ╰──────────────────────────────────────────────────────────────────────────╯
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ ⑧ EMAIL SMTP — Gửi mail thông báo (TUỲ CHỌN)                              │
# │                                                                          │
# │ Nếu để trống: chỉ Telegram, không gửi email.                              │
# │                                                                          │
# │ VÍ DỤ CẤU HÌNH GMAIL:                                                     │
# │   • Bật 2FA cho Gmail                                                    │
# │   • Tạo App Password tại https://myaccount.google.com/apppasswords        │
# │   • SMTP_HOST=smtp.gmail.com                                             │
# │   • SMTP_PORT=587                                                        │
# │   • SMTP_USER=your-email@gmail.com                                       │
# │   • SMTP_PASS=<app-password-16-chars>                                     │
# │   • SMTP_SECURE=false  (false cho port 587, true cho port 465)          │
# ╰──────────────────────────────────────────────────────────────────────────╯
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ ⑨ REMOTE SIGNING — Cloud CA (TUỲ CHỌN)                                    │
# │                                                                          │
# │ Tích hợp ký số qua API của Cloud CA (VNPT, Viettel, FPT, BKAV, ...).      │
# │ Để trống nếu chỉ dùng USB Token / VGCA.                                  │
# ╰──────────────────────────────────────────────────────────────────────────╯
REMOTE_CA_URL=
REMOTE_CA_API_KEY=
REMOTE_CA_PROVIDER=


# ╭──────────────────────────────────────────────────────────────────────────╮
# │ 📋 CHECKLIST TRƯỚC KHI DEPLOY VERCEL:                                     │
# │                                                                          │
# │   ☐ Tạo Turso DB và copy URL + Token                                     │
# │   ☐ Tạo 2 JWT secret bằng `openssl rand -hex 32`                         │
# │   ☐ Tạo Telegram bot + lấy chat_id                                       │
# │   ☐ Tạo Dropbox app + token (nếu muốn lưu Dropbox)                       │
# │   ☐ Vào Vercel Dashboard → Project Settings → Environment Variables      │
# │   ☐ Paste từng giá trị, tick cả 3 environments                           │
# │   ☐ Redeploy project (Deployments → ⋯ → Redeploy)                        │
# │   ☐ Test: curl https://your-app.vercel.app/api/health                    │
# │                                                                          │
# │ 📋 CHECKLIST CHẠY LOCAL:                                                  │
# │                                                                          │
# │   ☐ cp .env.example .env                                                 │
# │   ☐ Điền JWT_SECRET, JWT_REFRESH_SECRET                                  │
# │   ☐ (Tuỳ chọn) Điền Telegram + Dropbox                                   │
# │   ☐ npm install                                                          │
# │   ☐ npm start                                                            │
# │   ☐ Mở http://localhost:3000                                             │
# │   ☐ Login: admin@esign.local / admin123                                  │
# ╰──────────────────────────────────────────────────────────────────────────╯

# ╭──────────────────────────────────────────────────────────────────────────╮
# │ ⑩ GOOGLE SHEET — Nguồn dữ liệu người dùng (Nguoi_Dung)                     │
# │                                                                          │
# │ App đọc sheet "Nguoi_Dung" làm nguồn xác thực chính.                      │
# │ Sheet phải để chế độ "Anyone with the link → Viewer".                     │
# │ Layout cột: Mã NV | Họ tên | Email | SĐT | Chức vụ | Phòng ban |          │
# │              Phân quyền | Mật khẩu | Hình đại diện                         │
# │ ID lấy từ URL: docs.google.com/spreadsheets/d/<ID>/edit                   │
# ╰──────────────────────────────────────────────────────────────────────────╯
GOOGLE_SHEET_ID=
SHEET_CACHE_TTL_MS=300000
