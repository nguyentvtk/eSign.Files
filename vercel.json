{
  "version": 2,
  "builds": [
    { "src": "server/index.js", "use": "@vercel/node", "config": { "includeFiles": ["server/**", "public/**"] } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/index.js" },
    { "src": "/uploads/(.*)", "dest": "server/index.js" },
    { "src": "/css/(.*)", "dest": "public/css/$1" },
    { "src": "/js/(.*)", "dest": "public/js/$1" },
    { "src": "/assets/(.*)", "dest": "public/assets/$1" },
    { "src": "/(.*\\.(?:ico|png|jpg|svg|webp))", "dest": "public/$1" },
    { "src": "/(.*)", "dest": "public/index.html" }
  ]
}
